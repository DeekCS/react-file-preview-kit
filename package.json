{
  "name": "@kareem-dev/react-file-preview-kit",
  "version": "0.1.1",
  "description": "React file preview component with 50+ file type icons. Accepts extensions, MIME types, or filenames.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "tailwindcss": ">=3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "react",
    "file",
    "preview",
    "icon",
    "mime",
    "typescript",
    "tailwind"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeekCS/react-file-preview-kit.git"
  },
  "homepage": "https://github.com/DeekCS/react-file-preview-kit#readme",
  "bugs": {
    "url": "https://github.com/DeekCS/react-file-preview-kit/issues"
  }
}
